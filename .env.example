# Copy to .env and fill in. These override config.toml.

# --- Transaction source: pick ONE ---
#
# A) STANDARD RPC PLAN (no Geyser) — leave GRPC_ENDPOINT empty and set RPC_URL
#    below. volens uses WebSocket logsSubscribe. This works on a $50 Helius
#    developer plan. Detection is ~1.4-6s behind (measured), because
#    getTransaction cannot read below `confirmed` commitment.
#
# B) GEYSER PLAN — set GRPC_ENDPOINT + GRPC_X_TOKEN for the fast path.
#    Helius:    https://mainnet.helius-rpc.com   (x-token = your API key)
#    Triton:    https://<your>.rpcpool.com
#    QuickNode: https://<your>.solana-mainnet.quiknode.pro
#
# gRPC is always preferred when set; WebSocket is the automatic fallback.
GRPC_ENDPOINT=
GRPC_X_TOKEN=
GRPC_COMMITMENT=processed

# --- Telegram alerts (optional; setting the token auto-enables alerts) ---
# Create a bot with @BotFather, then get your chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Telegram commands (optional; must ALSO set commands_enabled = true) ---
# Who may run /status, /metrics, /halt. Comma-separated chat ids.
# Unlike the token above, this does NOT enable anything by itself — it says WHO
# may command the bot, not that commands should be accepted. Turn them on in
# config.toml ([alerts].commands_enabled), so remote control is never something
# you switch on by accident.
# /halt is a remote kill switch: anyone on this list can stop your trading.
TELEGRAM_AUTHORIZED_CHAT_IDS=

# --- RPC (REQUIRED for WebSocket mode; also powers liquidity + safety filters) ---
# Standard JSON-RPC endpoint. In WebSocket mode this is also the transaction
# source: the wss:// URL is derived from it automatically.
# Setting RPC_URL auto-enables the liquidity + safety filters.
RPC_URL=
# Minimum quote-side liquidity, in SOL for WSOL pairs / USDC for USDC pairs.
MIN_QUOTE_LIQUIDITY=5.0
# Only if your provider serves WebSocket on a different host/path than RPC_URL.
RPC_WS_URL=

# --- Logging ---
LOG_LEVEL=info
# RUST_LOG=volens=debug,warn
